# RogerAI broker - environment. Copy to `.env` and fill in (or set these as
# encrypted env vars in the DO App Platform UI). `.env` is gitignored.
#
# The broker reads: DATABASE_URL, PORT, ROGERAI_FEE, ROGERAI_SEED_CREDITS,
# ROGERAI_SEED_LIMIT, ROGERAI_DEFAULT_MONTHLY_CAP, MODERATION_PROVIDER/_URL/_MODEL,
# GROQ_API_KEY.
# (Clients `rogerai`/`rogerai share` need NONE of this - they just dial the broker.)

# --- DigitalOcean managed Postgres -------------------------------------------
# Reuse your existing cluster; RogerAI creates `rogerai_*` tables that coexist.
# DO gives you this string under the DB's "Connection Details" (use the pooled or
# direct URI). Port is usually 25060; keep sslmode=require.
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:25060/<DB_NAME>?sslmode=require

# --- Broker -------------------------------------------------------------------
PORT=8080                    # DO App Platform sets this automatically; harmless to leave.
ROGERAI_FEE=0.25             # platform take rate (0.25 = 25%).
ROGERAI_SEED_CREDITS=100     # free starting credits per new user (until the Stripe wallet lands).
# Seed CAP: bound total free-credit liability. Only the first ROGERAI_SEED_LIMIT
# DISTINCT wallets ever receive ROGERAI_SEED_CREDITS; after that, new users start at 0
# (they top up via Stripe). The seeded-user count is tracked durably (in Postgres a
# seed_counter row, bumped ATOMICALLY with each grant) so the cap holds under
# concurrency and never over-grants. Total free liability is bounded to
# SEED_LIMIT x SEED_CREDITS (default 1000 x 100 = 100000 credits). <=0 disables the cap.
ROGERAI_SEED_LIMIT=1000

# --- Price safety (GLOBAL: applied uniformly to every band + every consume path) --
# Two server-side guards, both env-tunable, both enforced by the broker no matter which
# client (CLI/TUI/web/raw API) made the request.
#
# 1) OPERATOR CEILING - a HARD per-1M-token cap a node may charge AT REGISTER. Enforced
#    for EVERY registration (public, --private, AND confidential) with NO flag exemption,
#    so a fat-fingered or deterrent price can never land on any band. A node that wants to
#    be unreachable to the public should go --private, not post an absurd price.
ROGERAI_MAX_PRICE_OUT=100      # $/1M output ceiling (well above any real model's rate).
ROGERAI_MAX_PRICE_IN=50        # $/1M input ceiling.
#
# 2) CONSUMER DEFAULT OUT-CAP - the DEFAULT out-price cap the broker applies to any relay
#    request that carries NO X-Roger-Max-Price-Out (defense in depth: the first-party
#    CLI/TUI always injects this, but a hand-rolled API client that omits it must not
#    silently bind to an exorbitant band). Applies on EVERY consume path - `use`, --freq,
#    grant-key use, the [0] AGENT harness relay, and the in-channel chat. A consumer that
#    sends a higher cap on purpose (e.g. --max-out 50) is honored as-is. <=0 disables the
#    backstop (the operator ceiling above then bounds the absolute max).
ROGERAI_CONSUMER_DEFAULT_MAX_PRICE_OUT=10   # $/1M output default consumer cap.

# --- Monthly spend cap (per-account budget limit; GLOBAL server-side) ---------
# A per-ACCOUNT max $ spend per CALENDAR month (modeled on Groq's "set a max you'll
# pay per month, notify + stop at the limit"). Opt-in: a user sets their own cap with
# `rogerai limit --monthly $X` (or the TUI [3] CONFIG); 0 = unlimited. Enforced at the
# broker credit-hold gate, so it is GLOBAL across every PAID consume path - `use`,
# --freq, grant-key use, the [0] AGENT harness, and the in-channel chat. A request
# whose worst-case cost would push month-to-date captured spend past the cap is
# REJECTED before dispatch; free / self-use ($0) is never blocked. The CLI/TUI + the
# broker response headers (X-RogerAI-Monthly-*) notify near (80%) and at (100%) the cap.
# ROGERAI_DEFAULT_MONTHLY_CAP is the STARTING cap for a new wallet (0 = unlimited, the
# default); each account can raise/lower/clear its own afterwards.
ROGERAI_DEFAULT_MONTHLY_CAP=0   # $ per calendar month for a new account (0 = unlimited).

# --- Domain (informational; you set this in Cloudflare DNS -> the DO app) ------
BROKER_DOMAIN=broker.rogerai.fyi

# --- Stripe (top-ups + Connect payouts) ---------------------------------------
# STRIPE_SECRET_KEY enables BOTH wallet top-ups (Checkout) AND operator payouts
# (Connect Express transfers). Leave blank in dev: top-ups + onboarding + transfers
# are stubbed with a loud log (no real money moves). Use a TEST key (sk_test_...)
# for sandbox. STRIPE_WEBHOOK_SECRET verifies the payment + dispute webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Operator payout policy (founder-approved defaults, OPTION A) --------------
# Earnings are held this many days before they become payable; there is NO separate
# rolling reserve (RESERVE=0) - the 90-day hold already covers the chargeback/dispute
# tail, so nothing extra is withheld past the hold. A payout requires at least the
# minimum (in credits, 1 credit = $ROGERAI_CREDIT_USD); schedule is monthly batched,
# manual request. KYC (Stripe Connect Express, transfers active) is mandatory before
# any withdrawal regardless of these knobs. Set RESERVE to a fraction in (0,1) only
# if you want to withhold an extra slice past the hold.
ROGERAI_PAYOUT_HOLD_DAYS=90
ROGERAI_PAYOUT_RESERVE=0
ROGERAI_PAYOUT_MIN=25
ROGERAI_PAYOUT_SCHEDULE=monthly
# Where Stripe returns the operator after Connect onboarding (optional overrides):
# STRIPE_CONNECT_REFRESH_URL=https://rogerai.fyi/payouts?onboard=refresh
# STRIPE_CONNECT_RETURN_URL=https://rogerai.fyi/payouts?onboard=done

# --- GitHub OAuth (P0 auth: login + monetization) -----------------------------
# OAuth App "RogerAI" owned by the rogerai-fyi org. The Client ID is public; the
# secret is sensitive - set it in .env / DO secrets ONLY, never commit it.
# Enable "Device Flow" on the app so `rogerai login` works in the terminal.
GITHUB_OAUTH_CLIENT_ID=Ov23liQE7Z6ITMbeJoF3
GITHUB_OAUTH_CLIENT_SECRET=

# --- Content moderation (mandatory pre-dispatch screen for launch) ------------
# The broker screens prompt text before EVERY LLM dispatch - the paid relay, the
# public Ping /concierge dogfood path, AND its Groq fallback all run the same screen,
# so no path can leak an unscreened prompt to a model.
#
# TWO backends, chosen by MODERATION_PROVIDER:
#   ""     (default) -> INFER: use "url" if MODERATION_URL is set, else "groq" if a
#                       GROQ_API_KEY is present, else OFF.
#   "url"            -> call MODERATION_URL (OpenAI-Moderation-compatible adapter).
#   "groq"           -> NATIVE Groq Llama Guard: no URL/adapter needed, the broker
#                       calls Groq's OpenAI-compatible chat/completions with a Llama
#                       Guard model using the SAME GROQ_API_KEY the concierge uses.
#
# >>> EASIEST: enable Groq Llama Guard with the key you already set for Ping:
#       GROQ_API_KEY=gsk_...            (already set for the concierge)
#       MODERATION_PROVIDER=groq
#       ROGERAI_REQUIRE_MODERATION=1    (fail-closed for public launch)
#     Llama Guard replies "safe" (allow) or "unsafe\n<categories>" (block 451). The
#     model id is overridable so you can fix the name without a redeploy:
#       MODERATION_MODEL=meta-llama/llama-guard-4-12b   (current default)
#
# URL backend contract: MODERATION_URL is POSTed {"input":"<latest user text>"} (short
# timeout); the response is parsed as either the OpenAI shape
# {"results":[{"flagged":bool,"categories":{...}}]} or {"flagged":bool}; flagged=true
# -> reject 4xx. Point it at the OpenAI Moderation API behind an auth proxy, or a tiny
# local adapter in front of a self-hosted Llama Guard speaking {input}->{flagged}.
#
# Fail mode (applies to BOTH backends):
#   no backend configured           -> screen INERT (serves normally, loud startup
#                                      warning). NOT safe for real public traffic.
#   backend set, REQUIRE=0          -> screen each request; flagged -> reject; a screen
#                                      error/timeout FAILS OPEN (logged, served) so a
#                                      screen outage does not down the marketplace.
#   backend set, REQUIRE=1          -> FAIL CLOSED: a screen error/timeout REJECTS
#                                      (503) rather than serving unscreened. REQUIRED
#                                      before public traffic.
# Launch checklist: set a backend (MODERATION_URL, or MODERATION_PROVIDER=groq +
# GROQ_API_KEY) AND ROGERAI_REQUIRE_MODERATION=1 before opening public traffic.
MODERATION_PROVIDER=          # "" (infer) | "url" | "groq"
MODERATION_URL=
MODERATION_MODEL=             # Groq Llama Guard model (default meta-llama/llama-guard-4-12b)
ROGERAI_REQUIRE_MODERATION=0

# CSAM (child-exploitation) handling: a flagged hit in one of these policy categories
# is NOT just rejected+discarded - the offending request is PRESERVED (encrypted at
# rest in rogerai.csam_incidents) and a CyberTipline report obligation is QUEUED, as
# required by US 18 USC 2258A. All OTHER unsafe categories keep the plain 451-reject
# (no preservation). Comma-separated, case-insensitive; matches Llama Guard codes (S4)
# and/or OpenAI category keys (sexual/minors). Default: "S4,sexual/minors".
ROGERAI_CSAM_CATEGORIES=

# --- Broker signing identity (fail-closed guard) ------------------------------
# BROKER_PRIVATE_KEY is the broker's stable ed25519 seed (64 hex chars / 32 bytes). It
# signs lineage receipts, derives the per-(user,node) pseudonyms, AND keys the web
# session-cookie HMAC, so it MUST be stable across restarts/redeploys or all three
# silently break. Leave blank in dev (an ephemeral key is generated, logged loud).
# ROGERAI_REQUIRE_BROKER_KEY=1 (the live broker) makes this FAIL CLOSED: if the key is
# unset/invalid the broker REFUSES TO BOOT instead of silently using an ephemeral key
# (mirrors ROGERAI_REQUIRE_LIVE for Stripe). Off (0) locally. Accepts 1/true/yes/on.
BROKER_PRIVATE_KEY=
ROGERAI_REQUIRE_BROKER_KEY=0

# --- Abuse reports + node eject (POST /report) --------------------------------
# Public abuse/quality reports POST /report {category,node_id?,request_id?,detail?} and
# are persisted to rogerai.reports (anonymous allowed; per-IP rate-limited by the relay
# limiter below). Once a node accumulates this many reports it is auto-EJECTED from
# routing (pick / /market / /discover), reusing the probe-eject mechanism. 0 disables
# auto-eject (a node can still be manually banned). Default 5.
ROGERAI_REPORT_EJECT_AT=5

# --- Rate limiting (per-caller token bucket on the relay) ---------------------
# Smooths bursts + caps sustained request rate so one caller can't flood the broker
# or a provider. RPM = sustained requests/min, BURST = bucket depth. RPM<=0 disables.
ROGERAI_RATE_RPM=120
ROGERAI_RATE_BURST=40

# --- Verification "Now" tier: L1 token re-count + active probe ----------------
# L1 INDEPENDENT TOKEN RE-COUNT. The broker re-tokenizes each completion with the
# canonical tokenizer for the model and reconciles it against the node's claim, so
# token over-reporting is detected. The re-count runs ASYNC off the request path
# against a separate tokenizer-sidecar process (see cmd/tokenizer-sidecar):
#   TOKENIZER_URL  - the sidecar base URL the broker calls. EMPTY = L1 disabled.
#   ROGERAI_RECOUNT_TOLERANCE - allowed over-report fraction before a node is
#                    flagged (0.02 = 2%); absorbs tokenizer-version drift.
TOKENIZER_URL=
ROGERAI_RECOUNT_TOLERANCE=0.02

# tokenizer-sidecar's OWN env (it is a SEPARATE process; run it next to the broker):
#   TOKENIZER_PORT - it listens on 127.0.0.1:$TOKENIZER_PORT (default 9099); then
#                    set TOKENIZER_URL=http://127.0.0.1:9099 above.
#   TOKENIZER_DIR  - optional dir of pinned per-model HuggingFace tokenizer.json
#                    files (exact non-tiktoken counts; the loader is a follow-up).
TOKENIZER_PORT=9099
TOKENIZER_DIR=

# ACTIVE CANARY + LATENCY PROBE. A broker goroutine periodically sends an unbilled
# canary job to each online, idle node, measuring TTFT + clean tok/s and checking a
# ROTATING deterministic fingerprint (liveness + coarse wrong-model gate; the prompt
# changes each round so a node cannot hard-code the answer). Feeds routing + the
# market verified-serving / ttft / speed signals, so nodes are MEASURED before any
# consumer traffic arrives. Probes are NEVER billed (result discarded, no wallet
# touched), skip busy nodes, and run concurrently with per-round jitter.
#
# The performance probe is ADAPTIVE so it stops hammering idle GPUs for data nobody
# is using, while staying fresh on demand (cheap liveness - the ~10s heartbeat /
# nodeTTL - is fully decoupled and ALWAYS on; only this expensive inference probe is
# made lazy):
#   - A freshly-on-air node is probed at the FLOOR; each idle round it survives
#     without traffic or demand DOUBLES its personal interval up to the CEILING, so a
#     persistently-idle node collapses toward ~one probe every ceiling (15m default)
#     instead of every 30s.
#   - REAL traffic supersedes probing: when a node serves a real request the broker
#     measured it for free, so its backoff RESETS to the floor and the next probe is
#     pushed out - an actively-used node is barely probed.
#   - DEMAND is just-in-time: a /discover or /market browse, or a pick about to route
#     to a candidate whose reading is stale, schedules that node for a near-term probe
#     (async - the request routes on current data; the probe refreshes for next time).
#     When demand subsides the idle backoff resumes.
#   - A node not measured within the ceiling is MODESTLY discounted in the signal
#     ("not recently verified") instead of us burning a probe; a fresh measurement
#     restores full confidence at once.
#   ROGERAI_PROBE_INTERVAL - seconds between probe rounds = the adaptive backoff
#                            FLOOR. ON by default (30s). Set 0 to disable entirely.
#   ROGERAI_PROBE_CEILING - max seconds an idle node backs off to (the loop still
#                            ticks at the floor; a backed-off node is just skipped
#                            until its later due-time). Default 900 (15m). Clamped to
#                            be >= the floor.
#   ROGERAI_PROBE_PER_OWNER - max nodes of a SINGLE owner probed per round (the rest
#                            are covered on following rounds via rotation), so a big
#                            multi-node owner is sampled, not hammered. 0 = no cap.
ROGERAI_PROBE_INTERVAL=30
ROGERAI_PROBE_CEILING=900
ROGERAI_PROBE_PER_OWNER=4
# Web (browser) login flow - optional overrides (defaults shown):
# GITHUB_OAUTH_REDIRECT=https://rogerai.fyi/auth/github/callback
# ROGERAI_DASHBOARD_URL=https://rogerai.fyi/dashboard
# ROGERAI_LOGIN_URL=https://rogerai.fyi/login
# ROGERAI_WEB_ORIGIN=https://rogerai.fyi   # allowed origin for credentialed (cookie) CORS
