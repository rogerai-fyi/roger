# Security headers - SOURCE OF TRUTH for the values, but NOT applied by hosting. The site
# runs on DigitalOcean App Platform, which does NOT read this Cloudflare-Pages/Netlify-style
# file (confirmed: none of these are on the live response). They are mirrored to the
# Cloudflare edge as a Response-Header Transform Rule by web/scripts/cf-edge.mjs, which reads
# THIS file so the two never drift - see web/EDGE.md. Edit a value here, then re-run that
# script. (The per-path Content-Type blocks below are likewise advisory on this stack.)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https://github.com https://avatars.githubusercontent.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'sha256-SnDneqm6BGJa6PkBRyNyh7dC65pFhdmWIclxI/UxeeU=' 'sha256-WZRJfWvsnNCPcxzZwvyhovnZGqhZaC+8gPGPRbx6wTk=' 'sha256-dhz791SJGjwR48M9Bg5QhzTI/dKpzDbXm+YjhUNkQHQ=' https://static.cloudflareinsights.com; connect-src 'self' https://broker.rogerai.fyi https://cloudflareinsights.com; form-action 'self'; upgrade-insecure-requests

# The installer must download as a plain script.
/install.sh
  Content-Type: text/x-shellscript; charset=utf-8
  Cache-Control: no-cache

# The Windows installer, served as plain text so `irm … | iex` gets the source.
/install.ps1
  Content-Type: text/plain; charset=utf-8
  Cache-Control: no-cache

# RFC 9116 security contact, served as plain text.
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
